{
  "name": "buildYourAgent",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "build": "wrangler deploy --dry-run --outdir dist",
    "check-types": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply buildyouragents --local",
    "db:migrate:prod": "wrangler d1 migrations apply buildyouragents --remote"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@huggingface/inference": "^4.13.21",
    "@langchain/core": "^1.2.1",
    "@langchain/textsplitters": "^1.0.1",
    "@llamaindex/liteparse-wasm": "^2.4.1",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "firecrawl": "^4.29.2",
    "hono": "^4.12.27",
    "openai": "^6.45.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260627.1",
    "@types/node": "^22.15.3",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.7.4",
    "wrangler": "^4.106.0"
  }
}
